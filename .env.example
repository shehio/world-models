# Environment variables for the wm-chess AWS pipeline.
#
# Copy to .env (gitignored) and fill in your own values, or leave the
# defaults if you're using the same account this repo was developed on.
#
# Consumed by:
#   - infra-eks/run.sh                       (cluster create / docker build / job submit)
#   - infra-eks/k8s/job-gen.yaml             (via envsubst)
#   - infra-eks/k8s/job-merge.yaml           (via envsubst)
#   - scripts that wrap aws cli              (e.g. salvage runs)
#
# Anything secret (AWS access keys, GitHub PATs) should live in ~/.aws/
# or a credential helper, NOT in this file.

# ---- AWS account + regions ----
AWS_ACCOUNT_ID=594561963943
AWS_PRIMARY_REGION=us-east-1
AWS_SECONDARY_REGION=eu-west-1

# ---- S3 buckets (one per region) ----
S3_BUCKET_US=wm-chess-library-594561963943
S3_BUCKET_EU=wm-chess-library-594561963943-eu-west-1

# ---- ECR repo (replicated to both regions) ----
ECR_REPO=wm-chess
ECR_IMAGE_TAG=latest
ECR_URI_US=594561963943.dkr.ecr.us-east-1.amazonaws.com/wm-chess
ECR_URI_EU=594561963943.dkr.ecr.eu-west-1.amazonaws.com/wm-chess

# ---- IAM (created via infra-eks/ + the merge-instance role) ----
EKS_CLUSTER_NAME=wm-chess
EKS_SERVICE_ACCOUNT=wm-chess-sa
MERGE_INSTANCE_ROLE=wm-chess-merge-instance-role
MERGE_INSTANCE_PROFILE=wm-chess-merge-instance-profile

# ---- Most recent run prefixes (per the May 2026 salvage) ----
# These point at the shards_partial trees that produced the merged/ datasets
# currently under each bucket. Update when launching a new run.
RUN_PREFIX_US=d15-mpv8-T1-g100000-20260512T1844Z
RUN_PREFIX_EU=d10-mpv8-T1-g250000-20260513T0615Z

# ---- Datagen defaults (overridable per Job) ----
DEPTH=15
MULTIPV=8
T_PAWNS=1.0
GAMES_PER_POD=12500
BASE_SEED=42
PARTIAL_SYNC_INTERVAL=600
