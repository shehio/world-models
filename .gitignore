# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Project artifacts
data/
checkpoints/
videos/
*.npz
*.pt
*.gif
*.mp4

# Allow small samples checked into the repo
!assets/**

# Local Claude Code state
.claude/

# Local environment (use .env.example as template; .env stays out of git)
.env
.env.local

# Terraform local state + provider cache (never commit these — provider
# binaries are hundreds of MB and tfstate may contain resource IDs)
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# Datasets and chunks live here; the CATALOG.md alongside is tracked.
library/games/
library/runs/

# Hugo site build output
site/public/
site/resources/
site/.hugo_build.lock

